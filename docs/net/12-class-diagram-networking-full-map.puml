together {
  package "Rex.Shared.Net" as pkgShared #DBEAFE {
    together {
      interface "IClientNetChannel" as ifcClientChan {
        + State : ConnectionState
        + RoundTripTimeMs : int
        + Send(message, channel, delivery) : void
        + Send(message) : void
        + Connect() : void
        + Disconnect(reason) : void
        + PollEvents() : void
        --
        + MessageReceived : Action<INetMessage>
        + Connected : Action
        + Disconnected : Action<string>
      }
      interface "IServerNetChannel" as ifcServerChan {
        + ClientId : Guid
        + IsLocal : bool
        + State : ConnectionState
        + RoundTripTimeMs : int
        + Send(message, channel, delivery) : void
        + Send(message) : void
        + Disconnect(reason) : void
      }
    }
    interface "INetMessage" as ifcNetMsg {
      + MessageId : ushort
      + Group : MessageGroup
      + Serialize(writer) : void
    }
    together {
      class "NetMessageRegistry" as clsMsgRegistry <<static>> {
        + {static} Register<T>(messageId, deserializer) : void
        + {static} Deserialize(reader) : INetMessage
        + {static} WriteHeader(writer, messageId) : void
      }
      class "LocalNetChannelPair" as clsLocalPair <<static>> {
        + {static} Create(clientId) : (LocalClientNetChannel, LocalServerNetChannel)
      }
      class "LocalClientNetChannel" as clsLocalClient {
        + State : ConnectionState
        + RoundTripTimeMs : int
        + Connect() : void
        + Send(message, channel, delivery) : void
        + Send(message) : void
        + Disconnect(reason) : void
        + PollEvents() : void
        --
        + MessageReceived : Action<INetMessage>
        + Connected : Action
        + Disconnected : Action<string>
      }
      class "LocalServerNetChannel" as clsLocalServer {
        + ClientId : Guid
        + IsLocal : bool
        + State : ConnectionState
        + RoundTripTimeMs : int
        + Send(message, channel, delivery) : void
        + Send(message) : void
        + Disconnect(reason) : void
        + DrainMessages(handler) : void
      }
    }
    together {
      enum MessageGroup {
        Core
        Entity
        EntityEvent
        Input
        Command
        Transfer
      }
      enum ConnectionState {
        Connecting
        Connected
        Authenticated
        InGame
        Disconnecting
        Disconnected
      }
      enum "NetMode" {
        Standalone
        Client
        ListenServer
        DedicatedServer
      }
    }
    together {
      class "MessageGroupExtensions" as clsMsgGroupExt <<static>> {
        + {static} GetDeliveryInfo(group) : (byte, DeliveryMethod)
      }
      class "AdaptiveReliability" as clsAdaptRel <<static>> {
        + {static} ReliableThreshold : int
        + {static} GetAdaptiveDelivery(message) : (byte, DeliveryMethod)
      }
      class "DeliveryChannel" as clsDelivChan <<static>> {
        + {static} Reliable : byte
        + {static} Snapshot : byte
        + {static} ReliableUnordered : byte
        + {static} Unreliable : byte
        + {static} Transfer : byte
        + {static} ReliableMethod : DeliveryMethod
        + {static} SnapshotMethod : DeliveryMethod
        + {static} ReliableUnorderedMethod : DeliveryMethod
        + {static} UnreliableMethod : DeliveryMethod
        + {static} TransferMethod : DeliveryMethod
      }
      class "ProtocolConstants" as clsProtoConst <<static>> {
        + {static} ProtocolVersion : ushort
        + {static} ConnectionKey : string
        + {static} HandshakeTimeoutMs : int
        + {static} DefaultPort : int
        + {static} DefaultTickRate : int
        + {static} DefaultMaxPlayers : int
        + {static} ListenProcessReadyLine : string
      }
      class "ConnectEndpointParser" as clsConnParse <<static>> {
        + {static} TryParse(connectAddress, defaultPort, host, port) : bool
      }
      class "RexNetStatistics" as clsRexNetStats {
        + BytesSent : long
        + BytesReceived : long
        + MessagesSent : long
        + MessagesReceived : long
        + RecordSent(messageId, bytes) : void
        + RecordReceived(messageId, bytes) : void
        + GetPerTypeStats() : Dictionary<ushort, (long, long)>
        + Reset() : void
      }
      class "NetGuidExtensions" as clsNetGuidExt <<static>> {
        + {static} PutGuid(writer, value) : void
        + {static} ReadGuid(reader) : Guid
      }
    }
    ifcClientChan -[hidden]down- ifcNetMsg
    ifcNetMsg -[hidden]down- clsMsgRegistry
    clsMsgRegistry -[hidden]down- MessageGroup
  }
}

