pkgShared -[hidden]right- pkgMsgs
pkgMsgs -[hidden]right- pkgXfer
pkgXfer -[hidden]right- pkgRexClient
pkgClientNet -[hidden]right- pkgDedicated

' --- Transport realizations (short hops inside shared + app columns) ---
ifcClientChan <|.. clsLocalClient
ifcClientChan <|.. clsRmtClient
ifcServerChan <|.. clsLocalServer
ifcServerChan <|.. clsRmtServer

clsLocalPair ..> clsLocalClient
clsLocalPair ..> clsLocalServer

' --- INetMessage family (horizontal fan from shared into Messages + Transfer) ---
ifcNetMsg <|.. msgConnReq
ifcNetMsg <|.. msgConnResp
ifcNetMsg <|.. msgDisc
ifcNetMsg <|.. msgStateAck
ifcNetMsg <|.. msgInput
ifcNetMsg <|.. msgSnap
ifcNetMsg <|.. msgSpawn
ifcNetMsg <|.. msgDestroy
ifcNetMsg <|.. msgBulkInit
ifcNetMsg <|.. msgBulkChunk
ifcNetMsg <|.. msgBulkAck

msgSnap *-- clsEntState

clsNetMsgs ..> clsMsgRegistry
clsMsgRegistry ..> ifcNetMsg

clsMsgGroupExt ..> MessageGroup
clsMsgGroupExt ..> clsDelivChan
clsAdaptRel ..> ifcNetMsg

clsBulkMgr ..> ifcClientChan
clsBulkMgr ..> ifcServerChan
clsBulkMgr ..> clsProtoSer
clsBulkMgr ..> clsNetCompress
clsBulkMgr ..> msgBulkInit
clsBulkMgr ..> msgBulkChunk
clsBulkMgr ..> BulkDataType
msgBulkInit ..> BulkDataType

dtoMap *-- dtoMapTile
dtoMap *-- dtoMapEnt
dtoAstMan *-- dtoAstEnt
dtoEntBulk *-- dtoBulkEnt

' --- Apps (dependencies mostly eastbound into Shared) ---
clsClientApp ..> NetMode
clsClientApp ..> clsProtoConst
clsClientApp *-- clsGameClient
clsGameClient ..> clsNetMsgs
clsGameClient *-- clsWorldState
clsGameClient *-- clsInputBuf
clsGameClient *-- clsPredSys
clsGameClient ..> ifcClientChan
clsGameClient ..> clsBulkMgr
clsGameClient ..> clsProtoConst

clsSrvApp ..> clsSrvCfg
clsSrvApp *-- clsGameSrv

clsGameSrv *-- clsGameHost
clsGameSrv ..> clsRmtServer
clsGameSrv ..> clsCliSession
clsGameHost *-- clsSrvCfg
clsGameHost o-- clsCliSession
clsCliSession ..> ifcServerChan
clsGameHost ..> clsBulkMgr
clsGameHost ..> clsRexNetStats
clsGameHost ..> msgBulkAck

note right of clsNetMsgs
  RegisterAll registers every sim message id plus
  BulkTransferInit, BulkTransferChunk, BulkTransferAck.
end note

note bottom of pkgShared
  Contracts and helpers used by both processes.
  ConnectionState lives on channel implementations.
end note

note bottom of pkgXfer
  DTO types are protobuf contracts reassembled after bulk transfer completes.
end note

note bottom of pkgClientNet
  GameClient polls IClientNetChannel and hosts BulkTransferManager for inbound bulk.
end note

note bottom of pkgSim
  GameServerHost logs BulkTransferAckMessage. Deserialize path matches GameClient.
end note

@enduml
